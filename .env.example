# Copy to `.env` and fill in. `.env` is git-ignored — never commit real secrets.
# All variables are read by jira_agent.config.Settings (prefix: none required).

# ── Anthropic (LLM) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model id. Opus for best judgment; Sonnet for cheaper/faster eval runs.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Jira Cloud ──────────────────────────────────────────────────────────────
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=...
# Service Desk project key the agent monitors (e.g. ITSD).
JIRA_PROJECT_KEY=ITSD

# ── Agent behavior ──────────────────────────────────────────────────────────
# A LOW retrieval-score floor: below this we DEFER (LOW_CONFIDENCE) because there
# was essentially no overlap. It is NOT the main gate — grounding + citation
# verification decide RESOLVE vs DEFER. Raw retrieval scores (TF-IDF or embeddings)
# don't separate the classes.
AGENT_CONFIDENCE_THRESHOLD=0.05
# How many policy sections to retrieve and show the answering LLM.
AGENT_RETRIEVAL_K=8
# Retriever: "local" (semantic embeddings — default, best accuracy; needs
# `uv sync --extra local-embeddings`) or "tfidf" (lexical baseline, no PyTorch).
AGENT_RETRIEVER=local
AGENT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Seconds between polls of the Service Desk queue.
AGENT_POLL_INTERVAL_SECONDS=30
# DRY_RUN=true logs the intended action but does NOT write to Jira. Start here.
AGENT_DRY_RUN=true
# Labels the agent applies.
AGENT_RESOLVED_LABEL=auto-resolved
AGENT_DEFER_LABEL=needs-human
# Optional: POST high-severity DEFER alerts (active incident / prompt injection) here.
# Unset = a structured high-severity log line instead.
# AGENT_SOC_WEBHOOK_URL=https://hooks.example.com/soc

# ── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json = structured logs for prod; console = human-readable for local dev.
LOG_FORMAT=console
