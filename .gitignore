# --- Secrets (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials*.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- uv ---
# uv.lock IS committed (reproducible installs); caches are not.
.uv/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# --- Local agent state / generated artifacts ---
.agent_state/
*.sqlite
*.db
reports/*.csv
reports/*.md
!reports/.gitkeep
tmp/

# --- Source material kept local, not published ---
input/

# --- Personal demo prep (kept local) ---
docs/LOOM_OUTLINE.md
docs/LOOM_SCRIPT.md

# --- Editor / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
